{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "custom_window",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "--local-engine=host_debug_unopt_arm64",
                "--local-engine-host=host_debug_unopt_arm64"
            ]
        },
        {
            "name": "custom_window (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "custom_window (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        {
            "name": "custom_window (attach)",
            "request": "attach",
            "type": "dart",
            "vmServiceInfoFile": "vmservice.json"
        },
        {
            "name": "custom_window C++ Attach",
            "type": "cppvsdbg",
            "request": "attach",
        }
    ]
}